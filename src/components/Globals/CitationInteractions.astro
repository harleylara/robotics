---
// src/components/Globals/CitationInteractions.astro
// Enhances rehypeCitation bibliography links with smooth scrolling, highlighting, and back-links.
---

<style is:global>
/* 
  Highlight animations for when a user clicks a citation to read the reference,
  or clicks the back-link to return to their reading spot.
*/

@keyframes progressive-highlight {
    0% {
        background-size: 0% 100%;
    }
    15% {
        background-size: 100% 100%;
        background-color: rgba(96, 165, 250, 0.2); 
    }
    80% {
        background-size: 100% 100%;
        background-color: rgba(96, 165, 250, 0.2); 
    }
    100% {
        background-size: 0% 100%;
        background-color: transparent;
    }
}

.citation-highlight {
    background-image: linear-gradient(to right, rgba(96, 165, 250, 0.2), rgba(96, 165, 250, 0.2)) !important;
    background-repeat: no-repeat !important;
    background-position: left center !important;
    background-size: 0% 100%;
    animation: progressive-highlight 2.8s ease-in-out forwards !important;
}

/* Ensure any internal elements don't block the background highlight */
.citation-highlight * {
    background-color: transparent !important;
}

.citation-back-link {
    text-decoration: none;
    margin-left: 8px;
    font-size: 0.9em;
    color: #60a5fa; /* Tailwind blue-400 */
    opacity: 0.7;
    transition: opacity 0.2s ease, transform 0.2s ease;
    display: inline-block;
}

.citation-back-link:hover {
    opacity: 1;
    transform: translateX(-2px);
}
</style>

<script>
if (typeof window !== 'undefined') {
    document.addEventListener('DOMContentLoaded', () => {
        // 1. Find all citation links generated by rehypeCitation
        // These are typically `a` tags where the href starts with `#bib-`
        const citationLinks = document.querySelectorAll('a[href^="#bib-"]');

        citationLinks.forEach(link => {
            // Check if it's wrapped in a rehypeCitation span (e.g., `<span id="citation--folland--12">`)
            // If not, assign a unique ID to the link itself.
            let sourceId = link.parentElement && link.parentElement.id ? link.parentElement.id : link.id;
            
            if (!sourceId) {
                sourceId = 'cite-' + link.getAttribute('href').substring(1) + '-' + Math.random().toString(36).substring(2, 7);
                link.id = sourceId;
            }

            link.addEventListener('click', (e) => {
                e.preventDefault();
                
                const targetId = link.getAttribute('href').substring(1); // e.g. 'bib-follandrealanalysismodern1999'
                const targetElement = document.getElementById(targetId);

                if (targetElement) {
                    // Inject a back-link if it doesn't already exist
                    let backLink = targetElement.querySelector('.citation-back-link');
                    if (!backLink) {
                        backLink = document.createElement('a');
                        backLink.href = '#' + sourceId;
                        backLink.className = 'citation-back-link';
                        backLink.textContent = '↩';
                        backLink.title = 'Return to reading';
                        
                        // Append to the end of the bibliography item
                        targetElement.appendChild(backLink);

                        // Attach the event listener to scroll back
                        backLink.addEventListener('click', (eBack) => {
                            eBack.preventDefault();
                            const returnTarget = document.getElementById(sourceId);
                            
                            if (returnTarget) {
                                // Smooth scroll back up to the paragraph
                                const yOffset = -150; // Offset for sticky headers/TOC
                                const y = returnTarget.getBoundingClientRect().top + window.pageYOffset + yOffset;
                                window.scrollTo({top: y, behavior: 'smooth'});

                                // Trigger the highlight flash on the actual link element specifically
                                link.classList.remove('citation-highlight');
                                void link.offsetWidth; // Trigger reflow
                                link.classList.add('citation-highlight');
                            }
                            
                            // Remove the backlink once it's used
                            backLink.remove();
                        });
                    } else {
                        // If it already exists (from a previous click), simply update the href
                        // to point to the *latest* clicked citation link in the text
                        backLink.href = '#' + sourceId;
                        
                        // We must also update the click listener. Since we can't easily remove anonymous
                        // functions, we clone and replace the node to wipe old listeners.
                        const newBackLink = backLink.cloneNode(true);
                        backLink.parentNode.replaceChild(newBackLink, backLink);
                        
                        // Re-attach fresh listener pointing to the new `sourceId`
                        newBackLink.addEventListener('click', (eBack) => {
                            eBack.preventDefault();
                            const returnTarget = document.getElementById(sourceId);
                            
                            if (returnTarget) {
                                const yOffset = -150; 
                                const y = returnTarget.getBoundingClientRect().top + window.pageYOffset + yOffset;
                                window.scrollTo({top: y, behavior: 'smooth'});

                                link.classList.remove('citation-highlight');
                                void link.offsetWidth; 
                                link.classList.add('citation-highlight');
                            }
                            
                            // Remove the backlink once it's used
                            newBackLink.remove();
                        });
                    }

                    // Smooth scroll down to the bibliography
                    const yOffset = -100; // Offset
                    const y = targetElement.getBoundingClientRect().top + window.pageYOffset + yOffset;
                    window.scrollTo({top: y, behavior: 'smooth'});

                    // Trigger highlight flash on the bibliography item
                    targetElement.classList.remove('citation-highlight');
                    void targetElement.offsetWidth; // Trigger reflow
                    targetElement.classList.add('citation-highlight');
                }
            });
        });
    });
}
</script>
